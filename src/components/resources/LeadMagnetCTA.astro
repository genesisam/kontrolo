---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
---

<div class="lead-magnet-cta-box">
  
  <Badge variant="black">DEJA DE CALCULAR A MANO</Badge>
  
  <h2 class="lead-magnet-title">
    ¿Cuánto tiempo pierdes en Excel cada mes?
  </h2>
  
  <p class="lead-magnet-desc">
    Automatiza tu nómina, liquidaciones, impuestos y contabilidad con Kontrolo. Un ecosistema completo conectado a la DIAN.
  </p>
  
  <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
    <Button href="/contacto" variant="primary">
      Empezar 15 Días Gratis
    </Button>
    <Button href="/contacto" variant="white-outline">
      Hablar con Asesor
    </Button>
  </div>
  
  <div style="margin-top: 32px; display: flex; gap: 24px; justify-content: center; opacity: 0.6; font-size: 13px; flex-wrap: wrap;">
    <span style="display: flex; align-items: center; gap: 6px;">✓ Nómina Electrónica</span>
    <span style="display: flex; align-items: center; gap: 6px;">✓ Facturación DIAN</span>
    <span style="display: flex; align-items: center; gap: 6px;">✓ Contabilidad Automatizada</span>
  </div>

</div>

<style>
  .lead-magnet-cta-box {
    background: linear-gradient(135deg, var(--color-dark) 0%, #1a1a2e 100%);
    color: var(--color-white);
    padding: 48px;
    border-radius: 24px;
    text-align: center;
    max-width: 900px;
    margin: 40px auto 0;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }
  .lead-magnet-title {
    font-size: 36px;
    margin-bottom: 20px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-white);
  }
  .lead-magnet-desc {
    font-size: 18px;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.5;
    color: var(--color-white);
  }

  @media (max-width: 767px) {
    .lead-magnet-cta-box {
      padding: 32px 20px;
      margin: 40px 16px 0;
      border-radius: 16px;
    }
    .lead-magnet-title {
      font-size: 28px;
    }
    .lead-magnet-desc {
      font-size: 16px;
      margin-bottom: 24px;
    }
  }
</style>
