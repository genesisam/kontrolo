---
import OptimizedImage from '../OptimizedImage.astro';

interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  imageUrl: string;
}

const { title, slug, description, category, imageUrl } = Astro.props;
---
<a href={`/recursos/contadores/${slug}`} style="text-decoration: none; color: inherit; background: #fff; border: 1px solid #eaeaea; border-radius: 16px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; height: 100%;" class="resource-card-hover">
  <div style="height: 200px; width: 100%; background: #eee; position: relative;">
    <div style="position: absolute; top: 16px; left: 16px; background: #0056ff; color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; z-index: 10;">
      {category}
    </div>
    <OptimizedImage src={imageUrl || 'images/gallery-img-04.jpg'} alt={title} class="resource-cover-image" />
  </div>
  <div style="padding: 24px; flex-grow: 1; display: flex; flex-direction: column;">
    <h3 style="font-size: 20px; font-weight: 700; margin: 0 0 12px 0; color: #111;">{title}</h3>
    <p style="color: #666; font-size: 14px; line-height: 1.5; margin-bottom: 24px; flex-grow: 1;">{description}</p>
    <div style="font-size: 14px; font-weight: 700; color: #0056ff; display: flex; align-items: center; gap: 8px;">
      Descargar gratis 
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </div>
  </div>
</a>

<style>
  .resource-card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
  }
  .resource-cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>