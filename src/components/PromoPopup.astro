---
// PromoPopup.astro
---
<div id="promo-popup" class="promo-popup-overlay">
  <div class="promo-popup-card">
    <button id="promo-close" class="promo-close" aria-label="Cerrar promoción">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    
    <div class="promo-header">
      <div class="promo-icon">
        🚀
      </div>
      <span class="promo-badge">OFERTA EXCLUSIVA</span>
    </div>

    <h3 class="promo-title">Impulsa tu empresa a la nube</h3>
    
    <p class="promo-text">
      Activa tu plan anual hoy y obtén un <strong>25% de descuento</strong> en nuestra suite integral de <strong>PMS, ERP y POS</strong> con facturación DIAN ilimitada.
    </p>

    <a href="https://api.whatsapp.com/send/?phone=573166973362&text=Hola+estoy+interesado+en+uno+de+sus+software&type=phone_number&app_absent=0" class="kontrolo-btn-primary" style="display: block; width: 100%; text-align: center; padding: 12px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; margin-bottom: 12px;" target="_blank" rel="noopener noreferrer">Contáctanos por WhatsApp</a>
    
    </div>
</div>

<style is:global>
  .promo-popup-overlay {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-family: 'Inter', sans-serif;
  }

  .promo-popup-overlay.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .promo-popup-card {
    background-color: #0f172a;
    border-radius: 12px;
    padding: 24px;
    width: 320px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
  }

  .promo-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    transition: color 0.2s;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .promo-close:hover {
    color: white;
  }

  .promo-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .promo-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--color-primary), #4f46e5);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .promo-badge {
    background-color: rgba(255, 193, 7, 0.2);
    color: #ffc107;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  .promo-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 10px 0;
    line-height: 1.3;
    color: var(--color-white); /* Explicit color to avoid overrides */
  }

  .promo-text {
    font-size: 13px;
    line-height: 1.5;
    color: #f1f5f9; /* Lighter slate */
    margin: 0 0 20px 0;
  }

  .promo-text strong {
    color: #4ade80; /* Accent color similar to image */
  }

  .promo-btn {
    display: block;
    width: 100%;
    background-color: var(--color-primary);
    color: white;
    text-align: center;
    padding: 12px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: background-color 0.3s;
    margin-bottom: 12px;
  }

  .promo-btn:hover {
    background-color: var(--color-primary-hover);
  }

  .promo-terms {
    font-size: 11px;
    color: #94a3b8; /* Lighter slate for better contrast */
    text-align: center;
    margin: 0;
  }

  .promo-terms a {
    color: #cbd5e1;
    text-decoration: underline;
  }

  .promo-terms a:hover {
    color: var(--color-white);
  }

  @media (max-width: 480px) {
    .promo-popup-overlay {
      bottom: 10px;
      left: 10px;
      right: 10px;
    }
    .promo-popup-card {
      width: auto;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('promo-popup');
    const closeBtn = document.getElementById('promo-close');

    // Verificar si el usuario ya cerró la promo antes
    const hasSeenPromo = sessionStorage.getItem('kontroloPromoClosed');

    if (!hasSeenPromo && popup) {
      // Mostrar después de 5 segundos
      setTimeout(() => {
        popup.classList.add('show');
      }, 5000);
    }

    if (closeBtn && popup) {
      closeBtn.addEventListener('click', () => {
        popup.classList.remove('show');
        // Guardar en session storage para no volver a mostrar en esta sesión
        sessionStorage.setItem('kontroloPromoClosed', 'true');
      });
    }
  });
</script>
