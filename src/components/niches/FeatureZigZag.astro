---
import OptimizedImage from '../OptimizedImage.astro';

interface Feature {
  title: string;
  description: string;
  featureImage: { asset: { url: string } };
  isReversed: boolean;
}

interface Props {
  features: Feature[];
}
const { features } = Astro.props;
---
<section class="section">
  <div class="container w-container">
    <div class="title-wrap" style="text-align: center; margin-bottom: 60px;">
      <div class="title-inner" style="justify-content: center;">
        <div class="subtitle bg-white">
          <div class="caption">BENEFICIOS</div>
        </div>
        <h2 class="title-heading animate-on-scroll animate-fade-up">Funcionalidades <span class="title-span">Principales</span></h2>
      </div>
    </div>
    {features.map((feature, index) => (
      <div class={`feature-zigzag-row ${feature.isReversed ? 'is-reversed' : ''}`}>
        <div style="direction: ltr;">
          <h3 class="title-heading" style="font-size: 32px; margin-bottom: 20px;">{feature.title}</h3>
          <p class="title-paragraph black">{feature.description}</p>
        </div>
        <div style="direction: ltr; border-radius: 20px; overflow: hidden; background: var(--color-gray-50); box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
          {feature.featureImage && feature.featureImage.asset && (
            <OptimizedImage src={feature.featureImage.asset.url} alt={feature.title} style="width: 100%; height: auto; display: block;" />
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .feature-zigzag-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 60px;
    margin-bottom: 100px;
  }
  
  .feature-zigzag-row.is-reversed {
    flex-direction: row-reverse;
  }

  @media (max-width: 991px) {
    .feature-zigzag-row,
    .feature-zigzag-row.is-reversed {
      flex-direction: column !important;
      gap: 30px;
      margin-bottom: 60px;
    }
    
    .feature-zigzag-row > div {
      direction: ltr !important; 
      width: 100%;
    }
  }
</style>
