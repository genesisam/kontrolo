---
interface Props {
  industryName: string;
}
const { industryName } = Astro.props;
---
<div class="sticky-cta" style="position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid #eaeaea; padding: 16px; display: flex; justify-content: space-between; align-items: center; z-index: 999; box-shadow: 0 -10px 30px rgba(0,0,0,0.05);">
  <div class="hide-mobile" style="font-weight: 600;">Comienza a optimizar tu {industryName} hoy mismo</div>
  <a href="/contacto" class="primary-button w-button" style="padding: 10px 24px; font-size: 14px;">Hablar con Asesor</a>
</div>
<style>
  @media (max-width: 767px) {
    .hide-mobile { display: none; }
    .sticky-cta { justify-content: center !important; }
  }
</style>
