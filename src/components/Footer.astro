---
import OptimizedImage from './OptimizedImage.astro';
import { sanityClient } from "sanity:client";
process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
let footerNiches = [];
try {
  footerNiches = await sanityClient.fetch(`*[_type == "niche"]{ "slug": slug.current, industryName, industryType } | order(_createdAt asc)[0...6]`);
} catch (error) {
  console.error("Sanity fetch error in Footer:", error.message);
}
