---
---
<section class="section" style="background-color: #f8fafc; padding: 100px 0;">
  <div class="container w-container">
    <div style="text-align: center; max-width: 800px; margin: 0 auto 60px;">
      <h2 class="title-heading animate-on-scroll animate-fade-up">Descubre cuánto estás perdiendo por no automatizar</h2>
      <p class="title-paragraph black animate-on-scroll animate-fade-up">Ingresa algunos datos de tu negocio y mira cuánto tiempo y dinero te devolverá Kontrolo cada mes.</p>
    </div>

    <div class="roi-wrapper animate-on-scroll animate-fade-up">
      <div class="roi-controls">
        <h4 style="margin-bottom: 24px; font-size: 18px;">Tus Datos</h4>
        
        <div class="roi-input-group">
          <label for="empleados">Número de empleados administrativos / cajeros</label>
          <input type="range" id="empleados" min="1" max="20" value="3" class="roi-range">
          <div class="roi-value" id="val-empleados">3</div>
        </div>

        <div class="roi-input-group">
          <label for="sistemas">¿Cuántos sistemas usas actualmente? (Excel, POS, Facturador, etc)</label>
          <input type="range" id="sistemas" min="2" max="6" value="4" class="roi-range">
          <div class="roi-value" id="val-sistemas">4</div>
        </div>

        <div class="roi-input-group">
          <label for="salario">Salario promedio mensual por empleado (COP)</label>
          <select id="salario" class="roi-select">
            <option value="1300000">Mínimo ($1.300.000)</option>
            <option value="2000000" selected>Promedio ($2.000.000)</option>
            <option value="3500000">Profesional ($3.500.000)</option>
          </select>
        </div>
        
        <div class="roi-info-box" style="margin-top: 32px; background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;">
          <h5 style="margin-bottom: 8px; font-size: 15px; color: #0f172a; font-weight: 700;">💡 El costo de los sistemas aislados</h5>
          <p style="margin: 0; font-size: 13px; color: #475569; line-height: 1.5;">Tener PMS, POS y contabilidad por separado genera reprocesos manuales diarios, pérdida de información y pagos de múltiples licencias. Kontrolo centraliza todo esto.</p>
        </div>
      </div>

      <div class="roi-results">
        <h3 style="font-size: 20px; font-weight: 700; margin-bottom: 24px; color: white;">Tu Ahorro Con Kontrolo</h3>
        
        <div class="result-box">
          <div class="result-label">Horas recuperadas al mes</div>
          <div class="result-number" id="res-horas">48h</div>
          <div class="result-desc">Cálculo: ~4 horas semanales perdidas por empleado saltando entre sistemas y corrigiendo errores.</div>
          <div class="result-desc" style="margin-top: 8px; font-style: italic;">* Los resultados son estimaciones basadas en promedio de industria.</div>
        </div>

        <div class="result-box highlight">
          <div class="result-label">Dinero ahorrado al mes</div>
          <div class="result-number highlight-text" id="res-dinero">$ 1.200.000</div>
          <div class="result-desc" style="color: #cbd5e1;">Cálculo: Valor de las horas recuperadas + eliminación de licencias extra.</div>
        </div>

        <div style="margin-top: 32px;">
          <a href="/contacto" class="kontrolo-btn kontrolo-btn-primary" style="background-color: #131ddf; color: white; width: 100%; text-align: center; border:none; padding: 16px 28px; border-radius: 42px; text-decoration: none; font-weight: 600; display: block;">Quiero este ahorro en mi empresa</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function calculateROI() {
    const empInput = document.getElementById('empleados');
    const sysInput = document.getElementById('sistemas');
    const salInput = document.getElementById('salario');
    
    if(!empInput || !sysInput || !salInput) return;

    const empleados = parseInt(empInput.value);
    const sistemas = parseInt(sysInput.value);
    const salario = parseInt(salInput.value);

    // Update display values
    const valEmp = document.getElementById('val-empleados');
    const valSys = document.getElementById('val-sistemas');
    if(valEmp) valEmp.innerText = empleados;
    if(valSys) valSys.innerText = sistemas;

    // Logic: Each system over 1 adds ~1 hour of manual work per employee per week
    const horasSemanales = empleados * (sistemas - 1) * 1; 
    const horasMensuales = horasSemanales * 4;

    // Costo hora = salario / 160 (aprox horas trabajadas al mes)
    const costoHora = salario / 160;
    
    // Ahorro sistemas (licencias) = (sistemas - 1) * 150000 COP aprox
    const ahorroLicencias = (sistemas - 1) * 150000;

    const dineroAhorradoMensual = Math.round((horasMensuales * costoHora) + ahorroLicencias);

    const resHoras = document.getElementById('res-horas');
    const resDinero = document.getElementById('res-dinero');
    if(resHoras) resHoras.innerText = `${horasMensuales}h`;
    if(resDinero) resDinero.innerText = `$ ${dineroAhorradoMensual.toLocaleString('es-CO')}`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const inputs = document.querySelectorAll('.roi-range, .roi-select');
    inputs.forEach(input => {
      input.addEventListener('input', calculateROI);
      input.addEventListener('change', calculateROI);
    });
    calculateROI();
  });
</script>

<style>
  .roi-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    overflow: hidden;
  }
  .roi-controls {
    padding: 40px;
  }
  .roi-results {
    background: #0a0a0a;
    color: white;
    padding: 40px;
  }
  .roi-input-group {
    margin-bottom: 24px;
  }
  .roi-input-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 12px;
    font-size: 14px;
    color: #475569;
  }
  .roi-range {
    width: 100%;
    accent-color: #131ddf;
    margin-bottom: 8px;
  }
  .roi-value {
    font-weight: 700;
    color: #131ddf;
    font-size: 18px;
    text-align: right;
  }
  .roi-select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-size: 15px;
    outline: none;
    font-family: inherit;
  }
  .result-box {
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .result-box.highlight {
    background: linear-gradient(135deg, rgba(19,29,223,0.2) 0%, rgba(19,29,223,0.05) 100%);
    border: 1px solid rgba(19,29,223,0.5);
  }
  .result-label {
    font-size: 14px;
    color: #94a3b8;
    margin-bottom: 8px;
  }
  .result-number {
    font-size: 36px;
    font-weight: 800;
    color: white;
    margin-bottom: 12px;
  }
  .highlight-text {
    color: #a5a9ff;
  }
  .result-desc {
    font-size: 13px;
    color: #64748b;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .roi-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>
