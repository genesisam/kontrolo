---
const { problems } = Astro.props;
---
<section class="section" style="background-color: #f7f8fa; padding: 100px 0;">
  <div class="container w-container">
    <div style="max-width: 800px; margin: 0 auto; text-align: center; margin-bottom: 60px;">
      <h2 class="title-heading animate-on-scroll animate-fade-up">{problems?.title || "¿Tu negocio funciona con 5 sistemas que no se hablan entre sí?"}</h2>
      <p class="title-paragraph black animate-on-scroll animate-fade-up">{problems?.description || "Excel para el inventario, un facturador aparte, las reservas en un cuaderno, la nómina donde el contador y las ventas en la memoria del cajero. Así se ve el caos que Kontrolo elimina:"}</p>
    </div>

    <div class="problem-grid animate-on-scroll animate-fade-up">
      {(problems?.problemCards || [
        { icon: '🧾', title: 'Miedo a la DIAN', description: 'Multas de hasta 1.5 UVT por factura electrónica no reportada a tiempo.' },
        { icon: '⏰', title: 'Horas perdidas', description: 'Digitar dos veces lo mismo en sistemas distintos te roba hasta <strong>12 horas semanales</strong>.' },
        { icon: '📦', title: 'Inventario fantasma', description: 'Vendes lo que ya no tienes y compras lo que no rota porque los datos no cuadran.' },
        { icon: '🛏️', title: 'Sobreventas de habitaciones', description: 'Dos huéspedes en la misma habitación: la reseña de 1 estrella ya está escrita.' },
        { icon: '📊', title: 'Ceguera gerencial', description: 'Te enteras de cuánto ganaste (o perdiste) un mes después, cuando ya es tarde.' },
        { icon: '💸', title: 'Costos ocultos', description: 'Cada sistema suelto es otra licencia, otro soporte y otro margen de error.' }
      ]).map((card: any) => (
        <div class="problem-card">
          <div class="problem-icon">{card.icon}</div>
          <h3 class="problem-title">{card.title}</h3>
          <p class="problem-desc" set:html={card.description}></p>
        </div>
      ))}
    </div>

    <div style="text-align: center; margin-top: 50px;" class="animate-on-scroll animate-fade-up">
      <p style="font-size: 18px; font-weight: 600; color: #64748b;">{problems?.bottomText || "Nada de esto es culpa tuya. Es culpa de tener herramientas desconectadas."}</p>
    </div>
  </div>
</section>

<style>
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .problem-card {
    background: var(--color-white);
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .problem-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .problem-icon {
    font-size: 32px;
    margin-bottom: 20px;
  }
  .problem-title {
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 12px;
  }
  .problem-desc {
    font-size: 15px;
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 991px) {
    .problem-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 767px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
