---
import OptimizedImage from '../OptimizedImage.astro';
import Badge from '../ui/Badge.astro';

interface Props {
  showButton?: boolean;
}

const { showButton = true } = Astro.props;
---
<section class="section" style="background-color: #050505; color: white; padding: 100px 0;">
  <div class="container w-container">
    <div class="dian-wrapper">
      <div class="dian-content animate-on-scroll animate-fade-up">
        <Badge variant="dian">Facturación Electrónica DIAN</Badge>
        <h2 class="title-heading color-white" style="margin-bottom: 24px;">La facturación electrónica dejó de ser un dolor de cabeza</h2>
        <p style="font-size: 18px; color: #94a3b8; line-height: 1.6; margin-bottom: 32px;">Olvídate de portales caídos, procesos largos y de contratar a un ingeniero para emitir una factura. Kontrolo lo hace por ti en segundo plano.</p>
        
        <ul class="dian-list">
          <li>
            <div class="dian-list-icon">⚡</div>
            <div>
              <strong>1 clic y listo</strong>
              <p>Se envía a la DIAN y al correo de tu cliente automáticamente.</p>
            </div>
          </li>
          <li>
            <div class="dian-list-icon">📄</div>
            <div>
              <strong>Resolución 000165 al día</strong>
              <p>Emite el Documento Equivalente Electrónico POS sin fricciones.</p>
            </div>
          </li>
          <li>
            <div class="dian-list-icon">💰</div>
            <div>
              <strong>Certificado Digital Incluido</strong>
              <p>Te ahorras más de $300.000 COP anuales. Todo viene en tu plan.</p>
            </div>
          </li>
          <li>
            <div class="dian-list-icon">📊</div>
            <div>
              <strong>El sueño de tu contador</strong>
              <p>Reportes automáticos, XML y PDF organizados para exportar.</p>
            </div>
          </li>
        </ul>

        {showButton && (
          <div style="margin-top: 40px;">
            <a href="/facturacion-electronica" class="kontrolo-btn kontrolo-btn-primary" style="background-color: var(--color-primary); color: white; border:none; padding: 16px 28px; border-radius: 42px; text-decoration: none; font-weight: 600; display: inline-block;">Ver facturación electrónica</a>
          </div>
        )}
      </div>

      <div class="dian-image-container animate-on-scroll animate-fade-up" style="transition-delay: 200ms;">
        <img src="/images/facturación electrónica.jpg" alt="Facturación Electrónica DIAN" style="width: 100%; max-width: 600px; display: block; margin: 0 auto; height: auto; border-radius: 16px; box-shadow: 0 20px 50px rgba(0,0,0,0.3);" />
      </div>
    </div>
  </div>
</section>

<style>
  .dian-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .dian-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .dian-list li {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    align-items: flex-start;
  }
  .dian-list-icon {
    font-size: 20px;
    background: rgba(255,255,255,0.05);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dian-list strong {
    color: white;
    display: block;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .dian-list p {
    color: #94a3b8;
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
  }
  
  .dian-mockup {
    background: #1e293b;
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    border: 1px solid #334155;
  }
  .mockup-header {
    padding: 12px 16px;
    display: flex;
    gap: 8px;
    border-bottom: 1px solid #334155;
  }
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #475569;
  }
  
  @media (max-width: 991px) {
    .dian-wrapper {
      grid-template-columns: 1fr;
    }
    .dian-image-container {
      margin-top: 40px;
    }
  }
</style>
