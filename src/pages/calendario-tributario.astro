      function calcularFechas(nit) {
        return calendarioDIAN[nit] || {
          renta: 'Fecha pendiente',
          iva: 'Fecha pendiente',
          rete: 'Fecha pendiente'
        };
      }

      btn.addEventListener('click', () => {
        const val = input.value.trim();
        
        if(!val || isNaN(val) || val.length > 2) {
          errorMsg.style.display = 'block';
          return;
        }
        
        errorMsg.style.display = 'none';
        
        // Formatear a 2 dígitos (Ej: 9 -> 09)
        const nitFormatted = val.padStart(2, '0');
        
        // Obtener fechas calculadas
        const fechas = calcularFechas(nitFormatted);

        // Actualizar UI
        nitDisplay.textContent = nitFormatted;
        fechaRenta.textContent = fechas.renta;
        fechaIva.textContent = fechas.iva;
        fechaRete.textContent = fechas.rete;

        // Mostrar/Ocultar secciones
        defaultMsg.style.display = 'none';
        resultadosHeader.style.display = 'block';
        tarjetasContainer.style.display = 'grid';
      });

      // Permitir 'Enter' para buscar
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          btn.click();
        }
      });
    });
