---
import { sanityClient } from "sanity:client";
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import Testimonial from '../components/Testimonial.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

const pageData = await sanityClient.fetch('*[_type == "solutionPage" && slug.current == "software-erp"][0]');

const seo = {
  title: pageData?.seo?.metaTitle || "Software ERP en la nube para empresas en Colombia | Kontrolo",
  description: pageData?.seo?.metaDescription || "Software ERP en la nube con facturación electrónica DIAN. Kontrolo organiza contabilidad, inventarios, compras y ventas en una sola plataforma.",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Kontrolo Software ERP",
    "description": "Software ERP en la nube con facturación electrónica DIAN para pymes en Colombia.",
    "brand": {
      "@type": "Brand",
      "name": "Kontrolo"
    }
  }
};
---
<MainLayout seo={seo}>
<div class="page-wrap">
<Hero 
  label={pageData?.hero?.label || "SOFTWARE ERP"}
  titleHtml={pageData?.hero?.headline || "El ERP en la Nube Ideal para <span class='kontrolo-primary-text'>Crecer sin Límites</span>"}
  subtitleHtml={pageData?.hero?.subheadline || "Organiza toda tu empresa. Desde contabilidad y facturación DIAN, hasta compras, ventas y conciliación bancaria en tiempo real."}
  primaryButtonText={pageData?.hero?.primaryButtonText || "Conoce Nuestro ERP"}
  primaryButtonLink={pageData?.hero?.primaryButtonLink || "/contacto"}
/>

<section class="section to-top">
<div class="w-layout-blockcontainer container w-container">
<div class="title-wrap" style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
  <div class="subtitle"><div class="caption">{pageData?.overview?.caption || "POTENCIA Y CONTROL"}</div></div>
  <h2 class="title-heading animate-on-scroll animate-fade-up">{pageData?.overview?.title || "Control absoluto de tu negocio en tiempo real"}</h2>
  <p class="title-paragraph black" style="margin: 0 auto;">{pageData?.overview?.description || "Optimiza tus recursos y simplifica procesos complejos. Toma el control de cada aspecto financiero, operativo y comercial desde un solo lugar."}</p>
</div>
<div class="feature-outer feature-software-pms">
  <div class="feature-card animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Contabilidad y DIAN automatizados" src="/images/kontrol-card-erp-1.jpg" class="cover-image"/></div>
    <div class="data-inner animate-on-scroll animate-fade-up">
      <h4 class="heading-14">Contabilidad y DIAN automatizados</h4>
      <p>Emite facturación electrónica DIAN, notas y recibos en segundos. Registra asientos automáticamente, gestiona impuestos y cierra periodos sin planillas manuales. Menos errores, más control financiero.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab241-36c7f59b" class="feature-card animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Inventarios y compras en tiempo real" src="/images/kontrol-card-erp-2.jpg" class="cover-image"/></div>
    <div class="data-inner animate-on-scroll animate-fade-up">
      <h4 class="heading-15">Inventarios y compras en<br>tiempo real</h4>
      <p>Controla stock por bodega y sucursal, lotes y costos. Reponer es simple con mínimos/máximos y órdenes de compra sugeridas. Evita quiebres y sobre-inventario.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab24c-36c7f59b" class="feature-card flex animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Ventas y clientes (CRM integrado)" src="/images/kontrol-card-erp-3.jpg" class="cover-image"/></div>
    <div class="data-inner small animate-on-scroll animate-fade-up">
      <h4 class="heading-16">Ventas y clientes<br>(CRM integrado)</h4>
      <p>Gestiona cotizaciones, pedidos y ventas en un flujo continuo. Consolida clientes, estados de cuenta y cartera. Acelera el cobro con recordatorios automáticos y reportes de rentabilidad por cliente.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab25a-36c7f59b" class="feature-flex">
    <div class="fill-block">
      <div class="feature-card animate-on-scroll animate-fade-up">
        <div class="feature-img large"><OptimizedImage alt="Tesorería y conciliación bancaria" src="/images/kontrol-card-erp-4.jpg" class="cover-image"/></div>
        <div class="data-inner animate-on-scroll animate-fade-up">
          <h4 class="heading-17">Tesorería y conciliación bancaria</h4>
          <p>Conecta bancos para conciliación automática, proyecta flujo de caja y controla egresos con aprobaciones. Visibilidad total de saldos, vencimientos y presupuestos.</p>
        </div>
      </div>
    </div>
    <div class="fill-block">
      <div class="feature-card animate-on-scroll animate-fade-up">
        <div class="feature-img large"><OptimizedImage alt="Nómina y costos operativos" src="/images/kontrol-card-erp-5.jpg" class="cover-image"/></div>
        <div class="data-inner animate-on-scroll animate-fade-up">
          <h4 class="heading-18">Nómina y costos operativos</h4>
          <p>Administra nómina, novedades y provisiones. Integra centros de costo para ver márgenes reales por sede, proyecto o línea de negocio. Cumple normativas sin hojas de cálculo.</p>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
</section>

<section class="section black-section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap" style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
<div class="subtitle-black" style="justify-content: center;">
<div class="caption">{pageData?.features?.caption || "FUNCIONALIDADES DESTACADAS"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up color-white">{pageData?.features?.title || "Descubre las potentes funciones del software ERP en la nube Kontrolo"}</h2>
<p class="title-paragraph" style="color: #a0aec0; margin-top: 15px;">{pageData?.features?.description || "Kontrolo ERP unifica contabilidad, ventas, compras, inventarios, nómina y facturación DIAN en una sola plataforma. Optimiza la gestión, reduce tareas manuales y facilita decisiones con datos actualizados en tiempo real."}</p>
</div>
<div class="choose-wrap">
  {(pageData?.features?.cards || [
    { icon: '🧾', title: 'Automatización contable avanzada', description: 'Ahorra horas de trabajo con asientos automáticos, cierre contable guiado y control tributario integrado.' },
    { icon: '🛒', title: 'Compras inteligentes y control de proveedores', description: 'Registra y aprueba órdenes de compra desde cualquier dispositivo.' },
    { icon: '💼', title: 'Ventas y gestión comercial conectada', description: 'Convierte cotizaciones en facturas con un clic, controla descuentos, márgenes y cuentas por cobrar.' },
    { icon: '💰', title: 'Tesorería y conciliación automática', description: 'Sincroniza tus bancos para realizar conciliaciones automáticas y proyecciones de flujo de caja.' },
    { icon: '📦', title: 'Gestión de inventarios y trazabilidad completa', description: 'Administra existencias por bodega, lote o número de serie.' },
    { icon: '📊', title: 'Reportes gerenciales y análisis estratégico', description: 'Visualiza métricas financieras, operativas y de rentabilidad en dashboards.' }
  ]).map((card: any) => (
    <div class="choose-card" >
      <div class="emoji-icon" style="font-size: 24px; background: rgba(255,255,255,0.05); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; margin-bottom: 20px;">{card.icon}</div>
      <div class="data-inner animate-on-scroll animate-fade-up">
        <h4 class="color-white" style="margin-bottom: 15px;">{card.title}</h4>
        <p>{card.description}</p>
      </div>
    </div>
  ))}
</div>
</div>
</div>
</section>
<section class="section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle">
<div class="caption">{pageData?.integrations?.caption || "INTEGRACIONES ERP"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up integration-width">{pageData?.integrations?.title || "Integraciones contables sin fricción con tu software ERP"}</h2>
</div>
<p class="title-paragraph black">{pageData?.integrations?.description || "Kontrolo ERP se conecta con sistemas contables, bancos, DIAN, plataformas de pago, e-commerce y nómina para sincronizar transacciones, facturas e inventarios en tiempo real, sin procesos manuales ni integraciones complejas."}</p>
</div>
<div class="choose-wrap" >
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/WOMPI.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">Wompi</h4>
<p>Pagos en línea y conciliación Cobra con PSE, tarjetas y Nequi desde Kontrolo. Sincroniza cada transacción con el módulo contable y actualiza saldos al instante. Reduce errores y mejora la experiencia con cobros seguros y confirmación inmediata.</p>
</div>
</div>
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/rinde-gastos.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">Rindegastos</h4>
<p>Gastos y reembolsos conectados Centraliza comprobantes y categorías, aplica flujos de aprobación y envía reembolsos al ERP. Obtén trazabilidad por centro de costo y acelera la rendición de viáticos con control y cumplimiento.</p>
</div>
</div>
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/DIAN.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">DIAN</h4>
<p>Facturación electrónica integrada Emite facturas y notas crédito validadas por la DIAN desde Kontrolo. Sincroniza CUFE y estados en tiempo real, automatiza el envío al cliente y asegura cumplimiento tributario sin procesos manuales.</p>
</div>
</div>
</div>
<div class="button-wrap" >
<a class="primary-button w-button" href="/integraciones">Ver integraciones</a>
</div>
</div>
</div>
</section>

<Testimonial />
<section class="section cta">
<div class="w-layout-blockcontainer container w-container">
<div class="cta-wrap">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle bg-white">
<div class="caption">{pageData?.cta?.caption || "COMIENZA HOY"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up">{pageData?.cta?.title || "Activa Kontrolo y centraliza tu operación en la nube"}</h2>
</div>
<p class="cta-paragraph">{pageData?.cta?.description || "Transforma tu negocio con Kontrolo, la suite de gestión empresarial que integra PMS, ERP y POS con facturación electrónica DIAN, pagos y CRM. Automatiza procesos, reduce errores y toma decisiones con datos en tiempo real."}</p>
</div>
<a class="primary-button w-button" href={pageData?.cta?.buttonLink || "/contacto"}>{pageData?.cta?.buttonText || "Solicitar demo gratuita"}</a>
</div>
</div>
</section>
</div>
</MainLayout>

