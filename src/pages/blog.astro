---
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
  title,
  "slug": slug.current,
  publishedAt,
  "authorName": author->name,
  "categoryName": categories[0]->title,
  "imageUrl": mainImage.asset->url
}`);

const seo = {
  title: "Blog - Kontrolo | Software ERP y Facturación DIAN",
  description: "Descubre Kontrolo, el software integral que centraliza PMS, ERP y POS con facturación electrónica DIAN. Agenda tu demo gratis."
};
---
<MainLayout seo={seo}>
<div class="page-wrap">
<section class="title-section">
<div class="w-layout-blockcontainer container w-container">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle">
<div class="caption">Blog</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up integration-width">Mantente informado sobre las <span class="title-span">últimas tendencias</span></h2>
</div>
<p class="title-paragraph black">Nuestro blog ofrece información valiosa sobre gestión financiera, tendencias del sector y cómo sacar el máximo partido a nuestra plataforma.</p>
</div>
</div>
</section>
<section>
<div class="w-layout-blockcontainer container w-container">
<div class="div-block">
{posts.map((post) => (
<a class="blog-card w-inline-block" href={`/blog/${post.slug}`}>
<div class="blog-thumb"><OptimizedImage alt={post.title} class="cover-image" loading="lazy" src={post.imageUrl || 'images/gallery-img-04.jpg'} /></div>
<div class="blog-content">
<div class="blog-outer">
<div class="blog-inner">
<div class="body-small">{post.authorName || 'Kontrolo'}</div>
<div class="body-small">-</div>
<div class="body-small">{new Date(post.publishedAt).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
</div>
<h5>{post.title}</h5>
</div>
<div class="learn-more">Leer más</div>
</div>
</a>
))}
</div>
</div>
</section>

<section class="section cta">
<div class="w-layout-blockcontainer container w-container">
<div class="cta-wrap">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle bg-white">
<div class="caption">COMIENZA HOY</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up"><span class="title-span">Activa Kontrolo </span>y centraliza tu operación en la nube</h2>
</div>
<p class="cta-paragraph">Transforma tu negocio con Kontrolo, la suite de gestión empresarial que integra PMS, ERP y POS con facturación electrónica DIAN, pagos y CRM. Automatiza procesos, reduce errores y toma decisiones con datos en tiempo real.</p>
</div>
<a class="primary-button w-button" href="#">Solicitar demo gratuita</a>
</div>
</div>
</section>
</div>
<style is:global>
  @media screen and (max-width: 991px) {
    .div-block {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media screen and (max-width: 767px) {
    .div-block {
      grid-template-columns: 1fr !important;
      width: 100%;
    }
    .blog-card {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
  }
</style>
</MainLayout>

