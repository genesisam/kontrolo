---
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
  title,
  "slug": slug.current,
  publishedAt,
  "authorName": author->name,
  "categoryName": categories[0]->title,
  "imageUrl": mainImage.asset->url
}`);

const seo = {
  title: "Blog - Kontrolo | Software ERP y Facturación DIAN",
  description: "Descubre Kontrolo, el software integral que centraliza PMS, ERP y POS con facturación electrónica DIAN. Agenda tu demo gratis."
};
---
<MainLayout seo={seo}>
<div class="page-wrap">
<section class="title-section">
<div class="w-layout-blockcontainer container w-container">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle">
<div class="caption">Blog</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up integration-width">Mantente informado sobre las <span class="title-span">últimas tendencias</span></h2>
</div>
<p class="title-paragraph black" style="margin-bottom: 40px;">Nuestro blog ofrece información valiosa sobre gestión financiera, tendencias del sector y cómo sacar el máximo partido a nuestra plataforma.</p>

{/* SEARCH BAR (HOSTINGER STYLE) */}
<div style="display: flex; width: 100%; max-width: 700px; margin: 0 auto; gap: 12px; flex-wrap: wrap; justify-content: center;">
  <div style="flex-grow: 1; position: relative; min-width: 250px; width: 100%;">
    <input type="text" id="blogSearchInput" placeholder="Buscar artículo, guía, tutorial..." style="width: 100%; padding: 18px 24px; border-radius: 50px; border: 1px solid var(--color-gray-200); font-size: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); outline: none; transition: all 0.2s;" class="resource-search-input" />
  </div>
  <button id="blogSearchBtn" class="kontrolo-btn-primary" style="padding: 16px 40px; border-radius: 50px; border: none; font-size: 16px; font-weight: 600; cursor: pointer;">Buscar</button>
</div>

</div>
</div>
</section>
<section>
<div class="w-layout-blockcontainer container w-container">
<div class="div-block" id="blogGrid">
{posts.map((post) => (
<a class="blog-card w-inline-block blog-item" href={`/blog/${post.slug}`} data-title={post.title?.toLowerCase() || ''} data-author={post.authorName?.toLowerCase() || ''} data-cat={post.categoryName?.toLowerCase() || ''}>
<div class="blog-thumb"><OptimizedImage alt={post.title} class="cover-image" loading="lazy" src={post.imageUrl || 'images/gallery-img-04.jpg'} /></div>
<div class="blog-content">
<div class="blog-outer">
<div class="blog-inner">
<div class="body-small">{post.authorName || 'Kontrolo'}</div>
<div class="body-small">-</div>
<div class="body-small">{new Date(post.publishedAt).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
</div>
<h5>{post.title}</h5>
</div>
<div class="learn-more">Leer más</div>
</div>
</a>
))}
</div>
<div id="emptyBlogState" style="display: none; text-align: center; padding: 60px 0; color: var(--color-gray-800); background: var(--color-gray-50); border-radius: 20px; border: 1px dashed var(--color-gray-300); margin-top: 20px;">
  <h3 style="font-size: 24px; margin-bottom: 10px;">No encontramos artículos</h3>
  <p>Intenta buscando con otras palabras clave.</p>
</div>
</div>
</section>

<section class="section cta">
<div class="w-layout-blockcontainer container w-container">
<div class="cta-wrap">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle bg-white">
<div class="caption">COMIENZA HOY</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up"><span class="title-span">Activa Kontrolo </span>y centraliza tu operación en la nube</h2>
</div>
<p class="cta-paragraph">Transforma tu negocio con Kontrolo, la suite de gestión empresarial que integra PMS, ERP y POS con facturación electrónica DIAN, pagos y CRM. Automatiza procesos, reduce errores y toma decisiones con datos en tiempo real.</p>
</div>
<a class="primary-button w-button" href="#">Solicitar demo gratuita</a>
</div>
</div>
</section>
</div>
<style is:global>
  body, html {
    overflow-x: hidden;
  }
  @media screen and (max-width: 991px) {
    .div-block {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media screen and (max-width: 767px) {
    .div-block {
      display: flex !important;
      flex-direction: column !important;
      gap: 20px;
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    .blog-card {
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    .title-heading, .title-paragraph {
      word-break: break-word;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('blogSearchInput');
    const btn = document.getElementById('blogSearchBtn');
    const items = document.querySelectorAll('.blog-item');
    const emptyState = document.getElementById('emptyBlogState');

    function performSearch() {
      const term = input.value.toLowerCase().trim();
      let visibleCount = 0;

      items.forEach(item => {
        const title = item.getAttribute('data-title') || '';
        const author = item.getAttribute('data-author') || '';
        const cat = item.getAttribute('data-cat') || '';

        if (title.includes(term) || author.includes(term) || cat.includes(term)) {
          item.style.display = 'flex'; // blog cards use flex in the template
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    if (input) {
      input.addEventListener('input', performSearch);
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') performSearch();
      });
    }
    if (btn) btn.addEventListener('click', performSearch);
  });
</script>

</MainLayout>

