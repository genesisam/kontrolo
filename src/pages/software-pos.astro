---
import { sanityClient } from "sanity:client";
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import Testimonial from '../components/Testimonial.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

const pageData = await sanityClient.fetch('*[_type == "solutionPage" && slug.current == "software-pos"][0]');

const seo = {
  title: pageData?.seo?.metaTitle || "Sistema POS con facturación electrónica DIAN | Kontrolo",
  description: pageData?.seo?.metaDescription || "Software de punto de venta (POS) en la nube para Colombia. Kontrolo es fácil, rápido y cumple con la facturación electrónica de la DIAN sin complicaciones.",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Kontrolo Software POS",
    "description": "Software de Punto de Venta (POS) en la nube con facturación electrónica DIAN integrada.",
    "brand": {
      "@type": "Brand",
      "name": "Kontrolo"
    }
  }
};
---
<MainLayout seo={seo}>
<div class="page-wrap">
<Hero 
  label={pageData?.hero?.label || "SISTEMA POS"}
  titleHtml={pageData?.hero?.headline || "Vende más rápido y cumple <span class='kontrolo-primary-text'>con la DIAN al instante</span>"}
  subtitleHtml={pageData?.hero?.subheadline || "Sistema de Punto de Venta (POS) rápido, intuitivo y con facturación electrónica integrada. Perfecto para restaurantes, tiendas y puntos físicos."}
  primaryButtonText={pageData?.hero?.primaryButtonText || "Ver Sistema POS"}
  primaryButtonLink={pageData?.hero?.primaryButtonLink || "/contacto"}
  imageDesktop="/images/software-pos-desktop.jpg"
  imageMobile="/images/software-pos-movil.jpg"
  bgColor="var(--color-gray-100)"
/>

<section class="section to-top">
<div class="w-layout-blockcontainer container w-container">
<div class="title-wrap" style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
  <div class="subtitle"><div class="caption">{pageData?.overview?.caption || "AGILIDAD EN EL MOSTRADOR"}</div></div>
  <h2 class="title-heading animate-on-scroll animate-fade-up">{pageData?.overview?.title || "Vende más, espera menos"}</h2>
  <p class="title-paragraph" style="margin: 0 auto;">{pageData?.overview?.description || "Transforma la experiencia en tu punto de venta. Agiliza cobros, controla inventarios al instante y mantén a tus clientes felices con un servicio rápido y sin errores."}</p>
</div>
<div class="feature-outer feature-software-pms">
  <div class="feature-card animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Ventas y facturación instantánea" src="/images/kontrol-card-pos-1.jpg" class="cover-image"/></div>
    <div class="data-inner animate-on-scroll animate-fade-up">
      <h4 class="heading-6">Ventas y facturación instantánea</h4>
      <p>Registra ventas con rapidez, aplica descuentos automáticos y genera facturación electrónica DIAN al instante. Controla métodos de pago mixtos (efectivo, tarjeta, transferencias) y evita errores con cierres automáticos de caja.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab241-66b9b636" class="feature-card animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Inventario sincronizado en tiempo real" src="/images/kontrol-card-pos-2.jpg" class="cover-image"/></div>
    <div class="data-inner animate-on-scroll animate-fade-up">
      <h4 class="heading-7">Inventario sincronizado en tiempo real</h4>
      <p>Supervisa entradas, salidas y existencias desde cualquier tienda o sucursal. Recibe alertas por niveles bajos de stock y actualiza precios o productos automáticamente en todos los puntos de venta.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab24c-66b9b636" class="feature-card flex animate-on-scroll animate-fade-up">
    <div class="feature-img"><OptimizedImage alt="Clientes y fidelización" src="/images/kontrol-card-pos-3.jpg" class="cover-image"/></div>
    <div class="data-inner small animate-on-scroll animate-fade-up">
      <h4 class="heading-8">Clientes y fidelización</h4>
      <p>Crea perfiles de clientes, registra compras recurrentes y gestiona programas de puntos o descuentos personalizados. Incrementa la recompra y mide el comportamiento de tus mejores clientes desde tu CRM integrado al POS.</p>
    </div>
  </div>
  <div id="w-node-_2fc916ed-0867-2277-56c6-83d7afeab25a-66b9b636" class="feature-flex">
    <div class="fill-block">
      <div class="feature-card animate-on-scroll animate-fade-up">
        <div class="feature-img large"><OptimizedImage alt="Tesorería y conciliación automática" src="/images/kontrol-card-pos-4.jpg" class="cover-image"/></div>
        <div class="data-inner animate-on-scroll animate-fade-up">
          <h4 class="heading-4">Tesorería y conciliación automática</h4>
          <p>Conecta tu POS con pasarelas de pago y bancos para conciliar ingresos automáticamente. Monitorea tu flujo de caja diario y proyecta ventas con reportes actualizados en tiempo real.</p>
        </div>
      </div>
    </div>
    <div class="fill-block">
      <div class="feature-card animate-on-scroll animate-fade-up">
        <div class="feature-img large"><OptimizedImage alt="Nómina y rendimiento del personal" src="/images/kontrol-card-pos-5-1.jpg" class="cover-image"/></div>
        <div class="data-inner animate-on-scroll animate-fade-up">
          <h4 class="heading-5">Nómina y rendimiento del personal</h4>
          <p>Administra turnos, propinas y comisiones desde el mismo panel. <br>Evalúa el rendimiento de tu equipo por ventas, horarios y productividad.</p>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
</section>

<section class="section black-section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap" style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
<div class="subtitle-black" style="justify-content: center;">
<div class="caption">{pageData?.features?.caption || "FUNCIONALIDADES DESTACADAS"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up color-white">{pageData?.features?.title || "Descubre las potentes funciones del software POS en la nube Kontrolo"}</h2>
<p class="title-paragraph" style="color: #a0aec0; margin-top: 15px;">{pageData?.features?.description || "Kontrolo POS conecta ventas, inventarios, clientes y métodos de pago en una sola plataforma. Optimiza la operación de tu negocio, controla tus puntos de venta en tiempo real y mejora la experiencia de tus clientes con un sistema rápido, seguro y totalmente en la nube."}</p>
</div>
<div class="choose-wrap">
  {(pageData?.features?.cards || [
    { icon: '🛒', title: 'Ventas rápidas y sin errores', description: 'Registra ventas en segundos con interfaz intuitiva y tickets automáticos. Aplica descuentos, combos o precios especiales sin depender del área administrativa.' },
    { icon: '📄', title: 'Facturación electrónica DIAN integrada', description: 'Cumple con la normativa vigente sin salir del POS. Genera facturas electrónicas y notas crédito en segundos, conectadas directamente con la DIAN.' },
    { icon: '📦', title: 'Gestión de inventario por sucursal', description: 'Actualiza existencias automáticamente cada vez que realizas una venta. Consulta el stock en todas tus sedes y recibe alertas de productos con bajo inventario.' },
    { icon: '🤝', title: 'CRM y fidelización de clientes', description: 'Registra clientes frecuentes, aplica programas de puntos y consulta historial de compras. Aumenta la recompra y crea promociones personalizadas.' },
    { icon: '💳', title: 'Pagos integrados y conciliación automática', description: 'Integra Wompi, PayU o Bancolombia para recibir pagos por tarjeta, PSE o QR. Las transacciones se registran automáticamente en tu sistema contable.' },
    { icon: '📊', title: 'Reportes inteligentes y control en tiempo real', description: 'Accede a paneles con métricas de ventas, márgenes, turnos y rentabilidad por producto o empleado.' }
  ]).map((card: any) => (
    <div class="choose-card" >
      <div class="emoji-icon" style="font-size: 24px; background: rgba(255,255,255,0.05); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; margin-bottom: 20px;">{card.icon}</div>
      <div class="data-inner animate-on-scroll animate-fade-up">
        <h4 class="color-white" style="margin-bottom: 15px;">{card.title}</h4>
        <p>{card.description}</p>
      </div>
    </div>
  ))}
</div>
</div>
</div>
</section>
<section class="section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle">
<div class="caption">{pageData?.integrations?.caption || "INTEGRACIONES PMS"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up integration-width">{pageData?.integrations?.title || "Integraciones contables sin fricción con tu software POS"}</h2>
</div>
<p class="title-paragraph black">{pageData?.integrations?.description || "Las integraciones de Kontrolo POS enlazan tu caja con contabilidad, bancos, DIAN, pasarelas de pago, e-commerce y nómina, para que cada venta actualice automáticamente facturas, cierres de caja e inventarios."}</p>
</div>
<div class="choose-wrap" >
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/WOMPI.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">Wompi</h4>
<p>Pagos en línea y conciliación Cobra con PSE, tarjetas y Nequi desde Kontrolo. Sincroniza cada transacción con el módulo contable y actualiza saldos al instante. Reduce errores y mejora la experiencia con cobros seguros y confirmación inmediata.</p>
</div>
</div>
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/rinde-gastos.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">Rindegastos</h4>
<p>Gastos y reembolsos conectados Centraliza comprobantes y categorías, aplica flujos de aprobación y envía reembolsos al ERP. Obtén trazabilidad por centro de costo y acelera la rendición de viáticos con control y cumplimiento.</p>
</div>
</div>
<div class="choose-card white-background"><OptimizedImage alt="Característica de software Kontrolo" loading="lazy" src="/images/DIAN.svg" width="130"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="ubuntu-black">DIAN</h4>
<p>Facturación electrónica integrada Emite facturas y notas crédito validadas por la DIAN desde Kontrolo. Sincroniza CUFE y estados en tiempo real, automatiza el envío al cliente y asegura cumplimiento tributario sin procesos manuales.</p>
</div>
</div>
</div>
<div class="button-wrap" >
<a class="primary-button w-button" href="/integraciones">Ver integraciones</a>
</div>
</div>
</div>
</section>

<Testimonial />
<section class="section cta">
<div class="w-layout-blockcontainer container w-container">
<div class="cta-wrap">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle bg-white">
<div class="caption">{pageData?.cta?.caption || "COMIENZA HOY"}</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up">{pageData?.cta?.title || "Activa Kontrolo y centraliza tu operación en la nube"}</h2>
</div>
<p class="cta-paragraph">{pageData?.cta?.description || "Transforma tu negocio con Kontrolo, la suite de gestión empresarial que integra PMS, ERP y POS con facturación electrónica DIAN, pagos y CRM. Automatiza procesos, reduce errores y toma decisiones con datos en tiempo real."}</p>
</div>
<a class="primary-button w-button" href={pageData?.cta?.buttonLink || "/contacto"}>{pageData?.cta?.buttonText || "Solicitar demo gratuita"}</a>
</div>
</div>
</section>
</div>
</MainLayout>

