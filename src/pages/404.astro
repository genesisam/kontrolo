---
import MainLayout from '../layouts/MainLayout.astro';

const seo = {
  title: "Página no encontrada | Kontrolo",
  description: "La página que buscas no existe o ha sido movida."
};
---
<MainLayout seo={seo}>
  <section class="section" style="padding: 120px 0; text-align: center; min-height: 70vh; display: flex; align-items: center; justify-content: center; background-color: #f8fafc;">
    <div class="container w-container">
      <div style="max-width: 600px; margin: 0 auto; background: white; padding: 60px 40px; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.05);">
        <div style="font-size: 120px; font-weight: 800; color: var(--color-primary); line-height: 1; margin-bottom: 20px;">404</div>
        <h1 class="title-heading" style="margin-bottom: 20px; font-size: 32px;">Página no encontrada</h1>
        <p style="font-size: 18px; color: #475569; margin-bottom: 40px;">Parece que te has perdido en la nube. La página que estás buscando no existe o ha sido movida.</p>
        <a href="/" class="primary-button w-button" style="display: inline-block;">Volver a Kontrolo</a>
      </div>
    </div>
  </section>
</MainLayout>
