---
import MainLayout from '../../layouts/MainLayout.astro';
import { sanityClient } from "sanity:client";
import ResourceCard from '../../components/resources/ResourceCard.astro';

// Fetch resources
const featuredResources = await sanityClient.fetch(`*[_type == "resource" && featured == true] | order(_createdAt desc)[0...3]{
  "slug": slug.current,
  title,
  description,
  resourceType,
  category,
  "imageUrl": coverImage.asset->url
}`);

const allResources = await sanityClient.fetch(`*[_type == "resource"] | order(_createdAt desc){
  title,
  "slug": slug.current,
  description,
  "imageUrl": coverImage.asset->url,
  category,
  resourceType,
  toolId
}`);

// Inject mock for development preview
const mockResource1 = {
  slug: 'calculadora-uvt-2026',
  title: 'Calculadora de UVT y Retención en la Fuente 2026',
  description: 'Convierte Pesos a UVT al instante y calcula automáticamente la retención en la fuente aplicable a tus honorarios y servicios.',
  resourceType: 'calculator',
  category: 'Calculadoras Financieras',
  imageUrl: null
};

const mockResource2 = {
  slug: 'calculadora-costo-empleado-2026',
  title: 'Calculadora de Costo Laboral de un Empleado 2026',
  description: 'Descubre el costo real de contratar a un empleado con todas las prestaciones, aportes parafiscales y seguridad social. Exoneración Art. 114-1 ET incluida.',
  resourceType: 'calculator',
  category: 'Calculadoras Financieras',
  imageUrl: null
};

const mockResource3 = {
  slug: 'simulador-liquidacion-laboral',
  title: 'Simulador de Liquidación Laboral',
  description: 'Calcula cuánto debes pagar o recibir por liquidación de prestaciones sociales e indemnizaciones por despido.',
  resourceType: 'calculator',
  category: 'Calculadoras Financieras',
  imageUrl: null
};

if (!allResources.some((r: any) => r.slug === mockResource1.slug)) {
  allResources.push(mockResource1);
  featuredResources.push(mockResource1);
}

const mockResource4 = { slug: 'calculadora-intereses-dian', title: 'Calculadora de Intereses DIAN', description: 'Simulador de intereses moratorios con tasa usura referencial.', resourceType: 'calculator', category: 'Calculadoras Financieras', imageUrl: null };
const mockResource5 = { slug: 'generador-contratos-laborales', title: 'Generador IA Contratos Laborales', description: 'Crea contratos a término indefinido al instante.', resourceType: 'ai-tool', category: 'Inteligencia Artificial', imageUrl: null };
const mockResource6 = { slug: 'buscador-codigos-ciiu', title: 'Buscador Códigos CIIU', description: 'Encuentra el código exacto para tu RUT.', resourceType: 'calculator', category: 'Guías y Documentos', imageUrl: null };

const mocks = [mockResource1, mockResource2, mockResource3, mockResource4, mockResource5, mockResource6];

mocks.forEach(mock => {
  if (!allResources.some((r: any) => r.slug === mock.slug)) {
    allResources.push(mock);
    featuredResources.push(mock);
  }
});

const categories = await sanityClient.fetch(`*[_type == "resourceCategory"]{ title, "slug": slug.current }`);

const seo = {
  title: 'Centro de Recursos y Herramientas Gratuitas | Kontrolo',
  description: 'Descubre calculadoras financieras, generadores de IA, plantillas Excel y guías para optimizar tu gestión contable y empresarial en Colombia.',
};
---

<MainLayout seo={seo}>
  <div class="page-wrap">
    
    {/* HERO HUB */}
    <section class="section recursos-hero-section">
      <div class="container w-container">
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
          <div class="subtitle">Centro de Recursos</div>
          <h1 class="title-heading recursos-hero-title">Herramientas para acelerar <br/><span style="color: #0056ff;">tu crecimiento empresarial</span></h1>
          <p class="title-paragraph black recursos-hero-desc">Calculadoras interactivas, plantillas listas para usar y asistentes impulsados por IA diseñados para ahorrarte horas de trabajo operativo.</p>
          
          {/* SEARCH BAR (HOSTINGER STYLE) */}
          <div style="display: flex; width: 100%; max-width: 700px; margin: 0 auto; gap: 12px; flex-wrap: wrap; justify-content: center;">
            <div style="flex-grow: 1; position: relative; min-width: 250px; width: 100%;">
              <input type="text" id="resourceSearchInput" placeholder="Buscar calculadora, plantilla, guía..." style="width: 100%; padding: 18px 24px; border-radius: 50px; border: 1px solid var(--color-gray-200); font-size: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); outline: none; transition: all 0.2s;" class="resource-search-input" />
            </div>
            <button id="resourceSearchBtn" class="kontrolo-btn-primary" style="padding: 16px 40px; border-radius: 50px; font-size: 16px; font-weight: 600; cursor: pointer;">Buscar</button>
          </div>
        </div>
      </div>
    </section>

    {/* CATÁLOGO DE HERRAMIENTAS */}
    <section class="section" style="padding: 80px 0; background: var(--color-white); min-height: 50vh;">
      <div class="container w-container">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
          <h2 style="font-size: 32px; margin-bottom: 0;">Catálogo de Herramientas</h2>
          <div style="font-size: 15px; color: var(--color-gray-800);">{allResources.length} disponibles</div>
        </div>
        
        {allResources.length === 0 ? (
          <div style="text-align: center; padding: 60px 0; color: var(--color-gray-800); background: var(--color-gray-50); border-radius: 20px; border: 1px dashed var(--color-gray-300);">
            <h3 style="font-size: 24px; margin-bottom: 10px;">Aún no hay recursos publicados.</h3>
            <p>Vuelve pronto para descubrir nuevas herramientas.</p>
          </div>
        ) : (
          <>
            <div id="resourcesGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px;">
              {allResources.map((resource: any) => (
                <div class="resource-item" data-title={resource.title?.toLowerCase() || ''} data-desc={resource.description?.toLowerCase() || ''} data-cat={resource.category?.toLowerCase() || ''}>
                  <ResourceCard 
                    title={resource.title} 
                    slug={resource.slug} 
                    description={resource.description} 
                    category={resource.category} 
                    imageUrl={resource.imageUrl} 
                    type={resource.resourceType}
                  />
                </div>
              ))}
            </div>
            <div id="emptySearchState" style="display: none; text-align: center; padding: 60px 0; color: var(--color-gray-800); background: var(--color-gray-50); border-radius: 20px; border: 1px dashed var(--color-gray-300); margin-top: 20px;">
              <h3 style="font-size: 24px; margin-bottom: 10px;">No encontramos resultados</h3>
              <p>Intenta buscando con otras palabras o navega por las categorías.</p>
            </div>
          </>
        )}
      </div>
    </section>

    {/* GLOBAL CTA */}
    <section class="section" style="background: var(--color-dark); color: var(--color-white); padding: 100px 20px;">
      <div class="container w-container" style="text-align: center;">
        <h2 style="font-size: 48px; margin-bottom: 24px; color: var(--color-white); letter-spacing: -0.02em;">¿Listo para ir más allá de las plantillas?</h2>
        <p style="font-size: 20px; color: var(--color-gray-500); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">Deja atrás el trabajo manual. Descubre cómo el ecosistema de Kontrolo automatiza tu facturación, nómina e inventario en un solo lugar.</p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href="/software-erp" class="primary-button w-button" style="padding: 18px 40px; font-weight: 700; border-radius: 50px; font-size: 16px;">Conocer el ERP</a>
          <a href="/contacto" class="secondary-button w-button" style="padding: 18px 40px; font-weight: 700; border-radius: 50px; font-size: 16px;">Agendar Demo</a>
        </div>
      </div>
    </section>

  </div>

  <style>
    .recursos-hero-title { font-size: 56px; line-height: 1.1; margin-bottom: 24px; }
    .recursos-hero-desc { font-size: 20px; margin-bottom: 40px; color: var(--color-gray-500); }

    @media (max-width: 991px) {
      .recursos-hero-title { font-size: 44px; }
    }
    @media (max-width: 767px) {
      .recursos-hero-title { font-size: 34px; line-height: 1.2; margin-bottom: 16px; }
      .recursos-hero-desc { font-size: 16px; margin-bottom: 24px; }
    }

    .resource-search-input:focus {
      border-color: var(--color-primary) !important;
      box-shadow: 0 0 0 4px rgba(19, 29, 223, 0.1);
    }
    
    .recursos-hero-section {
      padding-top: 160px;
      padding-bottom: 80px;
      background: linear-gradient(180deg, var(--color-gray-50) 0%, var(--color-white) 100%);
    }

    @media (max-width: 767px) {
      .recursos-hero-section { padding-top: 100px; padding-bottom: 40px; }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('resourceSearchInput');
      const btn = document.getElementById('resourceSearchBtn');
      const items = document.querySelectorAll('.resource-item');
      const emptyState = document.getElementById('emptySearchState');

      function performSearch() {
        const term = input.value.toLowerCase().trim();
        let visibleCount = 0;

        items.forEach(item => {
          const title = item.getAttribute('data-title') || '';
          const desc = item.getAttribute('data-desc') || '';
          const cat = item.getAttribute('data-cat') || '';

          if (title.includes(term) || desc.includes(term) || cat.includes(term)) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (emptyState) {
          emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      }

      if (input) {
        input.addEventListener('input', performSearch);
        input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') performSearch();
        });
      }
      if (btn) btn.addEventListener('click', performSearch);
    });
  </script>
</MainLayout>
