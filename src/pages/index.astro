      <a href="/alternativas" class="kontrolo-btn kontrolo-btn-outline animate-on-scroll animate-fade-up" style="display: inline-block; padding: 16px 32px; font-weight: 600;">Ver comparativa Kontrolo vs El Resto</a>
    </div>
  </div>
</section>

