---
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import Testimonial from '../components/Testimonial.astro';
import Hero from '../components/Hero.astro';

const seo = {
  title: "Kontrolo | PMS, ERP y POS en la nube para Colombia",
  description: "Centraliza tu negocio con Kontrolo: suite en la nube de PMS, ERP y POS. Gestiona reservas, ventas, inventarios y contabilidad con DIAN, pagos e informes en tiempo real.",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Kontrolo",
    "operatingSystem": "Cloud-based",
    "applicationCategory": "BusinessApplication",
    "description": "Suite en la nube de PMS, ERP y POS para hoteles y restaurantes en Colombia.",
    "offers": {
      "@type": "Offer",
      "priceCurrency": "COP"
    }
  }
};
---
<MainLayout seo={seo}>
<Hero 
  label="SOFTWARE DE GESTIÓN PARA CONTADORES Y PYMES"
  titleHtml="Toma el control de tu negocio <span class='kontrolo-primary-text'>con Kontrolo</span>"
  subtitleHtml="La suite definitiva en la nube que integra <strong>PMS, ERP y POS</strong> en un solo lugar. Automatiza tu contabilidad, controla tu inventario y emite <strong>facturación electrónica avalada por la DIAN</strong> sin complicaciones."
  primaryButtonText="Prueba 15 días Gratis"
  primaryButtonLink="/contacto"
/>
<div class="page-wrap">
<section class="section brand" style="padding-bottom: 30px;">
<div class="w-layout-blockcontainer container w-container">
<style is:global>
  .brand-slider {
    overflow: hidden;
    padding: 30px 0;
    width: 100%;
    position: relative;
    /* Efecto de desvanecimiento elegante en los bordes */
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }
  .brand-track {
    display: inline-flex;
    width: max-content;
    animation: scrollLogos 30s linear infinite;
  }
  .brand-track:hover {
    animation-play-state: paused;
  }
  .brand-set {
    display: flex;
    align-items: center;
    gap: 120px;
    padding-right: 120px; /* Mismo espacio del gap para mantener el ritmo */
  }
  .brand-set img {
    height: 85px; /* Tamaño mucho más grande para logos alargados */
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.5); /* Sutil y elegante */
    transition: filter 0.4s ease;
    cursor: pointer;
  }
  .brand-set img:hover {
    filter: grayscale(0%) opacity(1);
  }
  @keyframes scrollLogos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (max-width: 768px) {
    .brand-set { gap: 80px; padding-right: 80px; }
    .brand-set img { height: 50px; }
    .brand-slider {
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
  }
</style>

<div class="brand-wrap" style="width: 100%; text-align: center; overflow: hidden;">
<p style="opacity:1; margin-bottom: 10px; font-size: 13px; color: #64748b;">Más de 1 000 negocios en Colombia usan Kontrolo</p>

<div class="brand-slider">
  <div class="brand-track">
    <!-- Grupo Original -->
    <div class="brand-set">
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
    </div>
    <!-- Grupo Duplicado (Para el loop perfecto) -->
    <div class="brand-set">
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
    </div>
  </div>
</div>

</div>
</div>
</section>
<section class="section black-section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle-black" >
<div class="caption">Suite PMS · ERP · POS en la nube</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up color-white" >¿Por qué elegir Kontrolo?</h2>
</div>
<p class="title-paragraph" >Elige la suite que impulsa tu negocio con soluciones en la nube diseñadas para optimizar operaciones, reducir errores y mejorar la rentabilidad de cada área.</p>
</div>
<div class="choose-wrap" >
<div class="choose-card"><OptimizedImage alt="Característica de software Kontrolo" class="choose-icon" loading="lazy" src="/images/hotel-1.svg"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="color-white">Software PMS</h4>
<p>Administra reservas, check-in y check-out, housekeeping y facturación digital desde un solo panel. Aumenta tus reservas y mejora la experiencia del huésped.</p>
</div>
</div>
<div class="choose-card"><OptimizedImage alt="Característica de software Kontrolo" class="choose-icon" loading="lazy" src="/images/erp-1.svg"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="color-white">Software ERP</h4>
<p>Centraliza contabilidad, ventas, gastos, inventarios y nómina en un mismo sistema. Optimiza recursos, elimina errores y toma decisiones precisas en tiempo real.</p>
</div>
</div>
<div class="choose-card"><OptimizedImage alt="Característica de software Kontrolo" class="choose-icon" loading="lazy" src="/images/cubierta-de-alimentos-1.svg"/>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4 class="color-white">Software POS</h4>
<p><strong>Gestiona mesas, cocina e inventarios en tiempo real con facturación electrónica integrada. Reduce tiempos de espera y aumenta la rentabilidad de tu restaurante.</strong></p>
</div>
</div>
</div>
</div>
</div>
