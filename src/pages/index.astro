---
import OptimizedImage from '../components/OptimizedImage.astro';
import MainLayout from '../layouts/MainLayout.astro';
import Testimonial from '../components/Testimonial.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/home/ProblemSection.astro';
import SuiteSection from '../components/home/SuiteSection.astro';
import DianSection from '../components/home/DianSection.astro';
import Automations from '../components/home/Automations.astro';
import RoiCalculator from '../components/home/RoiCalculator.astro';
import SecuritySection from '../components/home/SecuritySection.astro';
import PricingSection from '../components/home/PricingSection.astro';
import BlogSection from '../components/home/BlogSection.astro';

const seo = {
  title: "Kontrolo | PMS, ERP y POS en la nube para Colombia",
  description: "Centraliza tu negocio con Kontrolo: suite en la nube de PMS, ERP y POS. Gestiona reservas, ventas, inventarios y contabilidad con DIAN, pagos e informes en tiempo real.",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Kontrolo",
    "operatingSystem": "Cloud-based",
    "applicationCategory": "BusinessApplication",
    "description": "Suite en la nube de PMS, ERP y POS para hoteles y restaurantes en Colombia.",
    "offers": {
      "@type": "Offer",
      "priceCurrency": "COP"
    }
  }
};
---
<MainLayout seo={seo}>
<Hero 
  label=""
  titleHtml="Software PMS, ERP y POS en la nube para tu negocio en Colombia"
  subtitleHtml="Reservas, ventas, inventario, contabilidad y facturación electrónica DIAN: todo tu negocio bajo Kontrolo. Para hoteles, restaurantes y comercios que quieren crecer sin enredos."
  primaryButtonText="Prueba gratis 15 días"
  primaryButtonLink="/registro"
  secondaryButtonText="Agendar una demo"
  secondaryButtonLink="/contacto"
/>
<div class="page-wrap">
<section class="section brand" style="padding-bottom: 30px;">
<div class="w-layout-blockcontainer container w-container">
<style is:global>
  .brand-slider {
    overflow: hidden;
    padding: 30px 0;
    width: 100%;
    position: relative;
    /* Efecto de desvanecimiento elegante en los bordes */
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }
  .brand-track {
    display: inline-flex;
    width: max-content;
    animation: scrollLogos 30s linear infinite;
  }
  .brand-track:hover {
    animation-play-state: paused;
  }
  .brand-set {
    display: flex;
    align-items: center;
    gap: 120px;
    padding-right: 120px; /* Mismo espacio del gap para mantener el ritmo */
  }
  .brand-set img {
    height: 85px; /* Tamaño mucho más grande para logos alargados */
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.5); /* Sutil y elegante */
    transition: filter 0.4s ease;
    cursor: pointer;
  }
  .brand-set img:hover {
    filter: grayscale(0%) opacity(1);
  }
  @keyframes scrollLogos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (max-width: 768px) {
    .brand-set { gap: 80px; padding-right: 80px; }
    .brand-set img { height: 50px; }
    .brand-slider {
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
  }
</style>

<div class="brand-wrap" style="width: 100%; text-align: center; overflow: hidden;">
<p style="opacity:1; margin-bottom: 10px; font-size: 13px; color: #64748b;">Más de 1 000 negocios en Colombia usan Kontrolo</p>

<div class="brand-slider">
  <div class="brand-track">
    <!-- Grupo Original -->
    <div class="brand-set">
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
    </div>
    <!-- Grupo Duplicado (Para el loop perfecto) -->
    <div class="brand-set">
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
      <OptimizedImage alt="La Gran Via" loading="lazy" src="/images/la-gran-via.png" />
      <OptimizedImage alt="Hotel Anapoima" loading="lazy" src="/images/hotel-anapoima.png" />
      <OptimizedImage alt="Hotel Dubai" loading="lazy" src="/images/hotel-dubai.png" />
    </div>
  </div>
</div>

</div>
</div>
</section>

<!-- S4: Problema -->
<ProblemSection />

<!-- S5: Suite -->
<SuiteSection />
<section class="section">
<div class="w-layout-blockcontainer container w-container">
<div class="section-inner">
<div class="title-wrap">
<div class="title-inner">
<div class="subtitle">
<div class="caption">Resultados reales: automatización, control y crecimiento</div>
</div>
<h2 class="title-heading animate-on-scroll animate-fade-up">Beneficios que transforman la <br/>‍<span class="title-span">gestión de tu negocio</span></h2>
</div>
<p class="title-paragraph black">Kontrolo es la suite de software en la nube para hoteles, restaurantes y empresas en Colombia que centraliza tus operaciones, automatiza procesos y potencia la rentabilidad.</p>
</div>
<div class="feature-outer">
<div class="feature-card animate-on-scroll animate-fade-up">
<div class="feature-img"><OptimizedImage alt="Característica de software Kontrolo" class="cover-image" loading="eager" src="/images/kontrol-card-1.jpg"/></div>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4>Automatización total de tu operación</h4>
<p>Reduce tareas manuales y elimina errores con un software ERP y PMS en la nube que integra contabilidad, inventarios, ventas y reservas. Ahorra hasta un 30 % del tiempo administrativo y mejora la productividad del equipo.</p>
</div>
</div>
<div class="feature-card animate-on-scroll animate-fade-up" id="w-node-_6e320c0a-4a24-79f3-ac6a-7d92730ffa63-730ffa5a">
<div class="feature-img"><OptimizedImage alt="Característica de software Kontrolo" class="cover-image" loading="eager" src="/images/kontrol-card-2.jpg"/></div>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4>Control centralizado desde cualquier lugar</h4>
<p>Gestiona tu negocio en tiempo real con una plataforma de gestión empresarial todo en uno. Supervisa ventas, gastos, reservas y stock desde cualquier dispositivo con conexión a internet.</p>
</div>
</div>
<div class="feature-card animate-on-scroll animate-fade-up flex" id="w-node-_6e320c0a-4a24-79f3-ac6a-7d92730ffa6b-730ffa5a">
<div class="feature-img"><OptimizedImage alt="Característica de software Kontrolo" class="cover-image" loading="eager" src="/images/kontrol-card-3.jpg"/></div>
<div class="data-inner animate-on-scroll animate-fade-up small">
<h4>Decisiones basadas en datos reales</h4>
<p>Obtén reportes automáticos y dashboards intuitivos con métricas de ventas, rentabilidad y desempeño. El software Kontrolo convierte tus datos en información estratégica para tomar mejores decisiones empresariales.</p>
</div>
</div>
<div class="feature-flex" id="w-node-_6e320c0a-4a24-79f3-ac6a-7d92730ffa73-730ffa5a">
<div class="fill-block">
<div class="feature-card animate-on-scroll animate-fade-up">
<div class="feature-img large"><OptimizedImage alt="Característica de software Kontrolo" class="cover-image" loading="lazy" src="/images/kontrol-card-4-1.jpg"/></div>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4>Ahorro de tiempo y recursos operativos</h4>
<p>Optimiza procesos y reduce costos con herramientas inteligentes de facturación electrónica, inventarios y nómina.Tu empresa gana eficiencia sin aumentar la carga operativa.</p>
</div>
</div>
</div>
<div class="fill-block">
<div class="feature-card animate-on-scroll animate-fade-up">
<div class="feature-img large"><OptimizedImage alt="Característica de software Kontrolo" class="cover-image" loading="lazy" src="/images/kontrol-card-5-1-1.jpg"/></div>
<div class="data-inner animate-on-scroll animate-fade-up">
<h4>Seguridad y cumplimiento garantizado</h4>
<p>Cumple con la DIAN y las normativas locales con un sistema respaldado por encriptación avanzada y copias automáticas en la nube.Tus datos están seguros las 24 horas del día.</p>
</div>
</div>
