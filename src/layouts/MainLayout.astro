---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PromoPopup from '../components/PromoPopup.astro';

export interface Props {
  seo?: {
    title?: string;
    description?: string;
    image?: string;
    canonical?: string;
    type?: string;
    structuredData?: any;
  };
}

const { seo = {} } = Astro.props;
---
<!DOCTYPE html>
<html lang="es-CO">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1" name="viewport"/>
  <SEO {...seo} />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700,800&display=swap" rel="stylesheet">
  <link href="/css/normalize.css" rel="stylesheet" type="text/css"/>
  <link href="/css/webflow.css" rel="stylesheet" type="text/css"/>
  <link href="/css/kontrolo.webflow.css" rel="stylesheet" type="text/css"/>
  <link href="https://fonts.googleapis.com" rel="preconnect"/>
  <link crossorigin="anonymous" href="https://fonts.gstatic.com" rel="preconnect"/>
  <script is:inline src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript"></script>
  <script is:inline type="text/javascript">WebFont.load({  google: {    families: ["Inter:regular,400,500,600,700"]  }});</script>
  <script is:inline type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>
  <link href="/images/favicon.png" rel="shortcut icon" type="image/x-icon"/>
  <link href="/images/webclip.png" rel="apple-touch-icon"/>
        <style is:global>
    img { height: auto; }
    body, p, a, li, span, div {
      font-family: 'General Sans', sans-serif;
    }
    h1, h2, h3, h4, h5, h6, .kontrolo-hero-title, .title-heading, .title-span, .footer-title, .pricing-title, .pricing-h2, .pricing-h3 {
      font-family: 'General Sans', sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: -0.02em !important;
    }
    .kontrolo-hero-title, h1 {
      font-weight: 800 !important; /* H1 un poco más pesado para impacto */
      letter-spacing: -0.03em !important;
    }
    .title-span {
      color: #131ddf !important; /* Kontrolo Blue */
    }
      /* Vanilla Animations */
    .animate-on-scroll {
      opacity: 0;
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }
    .animate-fade-up {
      transform: translateY(30px);
    }
    .animate-fade-in {
      transform: translateY(0);
    }
    .animate-on-scroll.is-visible {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
    
    /* FAQ Fixes */
    .answer-block.w-dropdown-list {
      display: block !important;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .answer-block.w-dropdown-list.w--open {
      max-height: 800px;
    }
    .w-dropdown-list:not(.answer-block) {
      display: none !important;
    }
    .w-dropdown-list.w--open:not(.answer-block) {
      display: block !important;
    }
    .faq-icon, .w-dropdown-toggle svg {
      transition: transform 0.3s ease;
    }
  </style>
</head>
<body>
  <Header />
  <slot />
  <Footer />
  <PromoPopup />
    <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Scroll Animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

      document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

      // 2. FAQ Accordions (Replaces w-dropdown JS)
      document.querySelectorAll('.w-dropdown-toggle').forEach(toggle => {
        toggle.addEventListener('click', function() {
          const parent = this.parentElement;
          const list = parent.querySelector('.w-dropdown-list');
          const icon = this.querySelector('.faq-icon') || this.querySelector('svg');
          
          const isOpen = parent.classList.contains('w--open');
          
          if (isOpen) {
            parent.classList.remove('w--open');
            this.classList.remove('w--open');
            if (list) list.classList.remove('w--open');
            if (icon) icon.style.transform = 'rotate(0deg)';
          } else {
            parent.classList.add('w--open');
            this.classList.add('w--open');
            if (list) list.classList.add('w--open');
            if (icon) icon.style.transform = 'rotate(180deg)';
          }
        });
      });

      // 3. Form Handling (Replaces w-form JS)
      document.querySelectorAll('.w-form form').forEach(form => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = form.querySelector('input[type="submit"]');
          const defaultText = btn ? btn.value : 'Enviar';
          if (btn) btn.value = btn.getAttribute('data-wait') || 'Enviando...';
          
          const parent = form.parentElement;
          const successBlock = parent.querySelector('.w-form-done');
          const errorBlock = parent.querySelector('.w-form-fail');
          
          if(errorBlock) errorBlock.style.display = 'none';
          
          try {
            const formData = new FormData(form);
            const response = await fetch(form.action, {
              method: 'POST',
              body: formData,
              headers: { 'Accept': 'application/json' }
            });
            
            if (response.ok) {
              form.style.display = 'none';
              if (successBlock) successBlock.style.display = 'block';
            } else {
              throw new Error('Error al enviar');
            }
          } catch (error) {
            console.error('Error submitting form:', error);
            if (errorBlock) errorBlock.style.display = 'block';
            if (btn) btn.value = defaultText;
          }
        });
      });
    });
  </script>
</body>
</html>
